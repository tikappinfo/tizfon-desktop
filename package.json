{
  "name": "tizfon-desktop",
  "version": "1.0.1",
  "description": "Tizfon Desktop — open-source Windows desktop client for the Tizfon cloud phone (Electron).",
  "author": "Tizfon",
  "license": "MIT",
  "homepage": "https://tizfon.com",
  "repository": { "type": "git", "url": "https://github.com/tikappinfo/tizfon-desktop.git" },
  "bugs": { "url": "https://github.com/tikappinfo/tizfon-desktop/issues" },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win dir --x64",
    "dist": "electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "com.tizfon.desktop",
    "productName": "Tizfon",
    "copyright": "Tizfon",
    "directories": { "output": "dist", "buildResources": "build" },
    "files": ["main.js", "preload.js", "assets/**/*"],
    "win": {
      "target": ["nsis"],
      "icon": "build/icon.ico",
      "artifactName": "Tizfon-Setup-${version}.${ext}",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tizfon",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  }
}
